# ── Server ──────────────────────────────────────────────────────────────────
PORT=7860
FRONTEND_ORIGIN=http://localhost:5173        # frontend dev origin, for CORS

# ── Supabase (server-side, service role — NEVER expose to the client) ─────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM — provider priority: Groq → OpenAI → Gemini (set at least one) ────────
# Groq is the recommended free default: no credit card, ~14.4k requests/day.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant            # optional override
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini                    # optional override
# GEMINI_API_KEY=                            # free fallback (only ~20 req/day)
# GEMINI_MODEL=gemini-2.5-flash-lite         # optional override

# ── Web search fallback + book metadata ──────────────────────────────────────
TAVILY_API_KEY=
GOOGLE_BOOKS_API_KEY=                         # optional — public Books search works without a key

# No embedding API key — embeddings run locally via Transformers.js.
# No YouTube API key — transcript via library, title via oEmbed (both keyless).
